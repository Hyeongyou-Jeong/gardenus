rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isUserOwnerByAuthUid(loginId) {
      return request.auth != null
             && get(/databases/$(database)/documents/users/$(loginId)).data.authUid == request.auth.uid;
    }

    // ── users/{uid} ──
    match /users/{uid} {
      function protectedUserFields() {
        return [
          "schoolVerified",
          "schoolVerifiedAt",
          "schoolVerifiedDetectedSchool",
          "studentIdVerificationStatus",
          "studentIdVerificationReason",
          "studentIdVerificationLastDetectedSchool",
          "schoolVerifyRewardedAt",
          "flower"
        ];
      }

      function hasProtectedFieldsOnCreate() {
        return request.resource.data.keys().hasAny(protectedUserFields());
      }

      function touchesProtectedFieldsOnUpdate() {
        return request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasAny(protectedUserFields());
      }

      function touchesImmutableGenderOnUpdate() {
        return resource.data.gender != null
               && request.resource.data.gender != resource.data.gender;
      }

      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.loginId is string
                    && request.resource.data.loginId == uid
                    && request.resource.data.authUid == request.auth.uid
                    && !hasProtectedFieldsOnCreate();

      allow update: if request.auth != null
                    && resource.data.authUid is string
                    && resource.data.authUid == request.auth.uid
                    && request.resource.data.authUid == resource.data.authUid
                    && !touchesImmutableGenderOnUpdate()
                    && !touchesProtectedFieldsOnUpdate();

      // ── users/{uid}/notifications/{notifId} ──
      match /notifications/{notifId} {
        allow read: if request.auth != null
                    && isUserOwnerByAuthUid(uid);

        allow create: if false;

        // readAt 필드만 수정 허용 (읽음 처리)
        allow update: if request.auth != null
                      && isUserOwnerByAuthUid(uid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"]);

        allow delete: if false;
      }
    }

    // ── payments/{paymentId} ──
    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // ── matchRequests/{fromUid}_{toUid} ──
    // fromUid/toUid는 loginId 문자열
    match /matchRequests/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.fromUid is string
                    && request.resource.data.toUid is string
                    && request.resource.data.status == "PENDING";

      allow update: if request.auth != null
                    && request.resource.data.fromUid == resource.data.fromUid
                    && request.resource.data.toUid == resource.data.toUid
                    && request.resource.data.createdAt == resource.data.createdAt
                    && (
                      // 보낸 사람: CANCELED 로만 전환 가능
                      (isUserOwnerByAuthUid(resource.data.fromUid)
                       && request.resource.data.status == "CANCELED")
                      ||
                      // 받는 사람: ACCEPTED 또는 DECLINED 로만 전환 가능
                      (isUserOwnerByAuthUid(resource.data.toUid)
                       && request.resource.data.status in ["ACCEPTED", "DECLINED"])
                    );

      // 보낸 사람만 삭제 가능
      allow delete: if request.auth != null
                    && isUserOwnerByAuthUid(resource.data.fromUid);
    }

    // ── matches/{minUid}_{maxUid} ──
    match /matches/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userA is string
                    && request.resource.data.userB is string
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.sourceRequestId is string;
      allow update, delete: if false;
    }

    // ── chatRooms ──
    match /chatRooms/{roomId} {
      allow read, write: if request.auth != null;

      // leave/poke 상태는 서버 함수만 기록
      match /members/{memberUid} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /pokeStats/{uid} {
        allow read, write: if false;
      }

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── directchat ──
    match /directchat/{chatId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /{sub=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
